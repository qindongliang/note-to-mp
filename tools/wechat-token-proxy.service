[Unit]
Description=WeChat token proxy for NoteToMP
After=network-online.target

[Service]
Type=simple
Environment=HOST=127.0.0.1
Environment=PORT=8787
EnvironmentFile=-/home/qindongliang/.config/wechat-token-proxy.env
ExecStart=/usr/bin/python3 /home/qindongliang/.local/bin/wechat-token-proxy.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
